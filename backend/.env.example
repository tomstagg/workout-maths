# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/workout_maths

# App
APP_ENV=development
SECRET_KEY=  # required: generate with: openssl rand -hex 32

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=  # required: set a strong password

# CORS (comma-separated, defaults to http://localhost:3000)
CORS_ALLOWED_ORIGINS=

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
