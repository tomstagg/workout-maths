{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install ."
  },
  "deploy": {
    "preDeployCommand": "PATH=/mise/shims:/mise/installs/python/3.12.13/bin:$PATH alembic upgrade head",
    "startCommand": "PATH=/mise/shims:/mise/installs/python/3.12.13/bin:$PATH uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
